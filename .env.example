# ==========================================
# AlgoLog - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---------- Database ----------
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_db_password

# ---------- JWT ----------
# Must be at least 32 characters. Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_key_min_32_chars_long_here
JWT_EXPIRY_MS=604800000

# ---------- Admin ----------
ADMIN_EMAIL=your_admin_email@example.com

# ---------- URLs ----------
# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://yourdomain.com
# Backend API URL that the frontend calls
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_URL=https://api.yourdomain.com

# ---------- OAuth2 - Google ----------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- OAuth2 - GitHub ----------
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Cloudinary ----------
# Get from: https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Brevo (Email) ----------
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_SENDER_NAME=AlgoLog
BREVO_TEMPLATE_ID=0
